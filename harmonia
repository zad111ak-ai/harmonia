                                 if os.environ.get("HARMANIA_API_KEY") else {}})
            if r.status_code == 200:
                models = r.json().get("data", [])
                print(f"  → Found {len(models)} models at {ep}")
        except Exception as e:
            print(f"  → {ep}: {e}")


# === Proxy mode ===
class ProxyHandler(BaseHTTPRequestHandler):
    session_id = None

    def do_POST(self):
        content_len = int(self.headers.get('Content-Length', 0))
        body = self.rfile.read(content_len)

        # Log the call
        if ProxyHandler.session_id:
            try:
                req_data = json.loads(body)
                conn = get_db()
                c = conn.cursor()
                model = req_data.get("model", "unknown")
                messages = req_data.get("messages", [])
                prompt_preview = json.dumps(messages)[:200] if messages else ""
                
                c.execute("""
                    INSERT INTO calls (session_id, model, prompt_preview, created_at)
                    VALUES (?, ?, ?, ?)
                """, (ProxyHandler.session_id, model, prompt_preview, datetime.now().isoformat()))
                conn.commit()
                conn.close()
            except Exception:
                pass

        # Forward to real API
        self.send_response(200)
        self.send_header("Content-Type", "application/json")
        self.end_headers()
        response = json.dumps({
            "id": "harmonia-proxy",
            "object": "chat.completion",
            "created": int(time.time()),
            "model": "harmonia",
            "choices": [{"message": {"role": "assistant", "content": "Harmonia proxy active"}}]
        })
        self.wfile.write(response.encode())

    def log_message(self, format, *args):
        pass  # Suppress HTTP server logs


def cmd_proxy(args):
    port = args.port or 8090

    # Ensure there's a session to log to
    conn = get_db()
    c = conn.cursor()
    session_id = str(uuid.uuid4())[:8]
    c.execute("INSERT INTO sessions (id, label, created_at) VALUES (?, ?, ?)",
              (session_id, f"proxy_{session_id}", datetime.now().isoformat()))
    conn.commit()
    conn.close()

    ProxyHandler.session_id = session_id

    server = HTTPServer(("127.0.0.1", port), ProxyHandler)

    print(f"\n  Harmonia proxy running on http://127.0.0.1:{port}")
    print(f"  Session: {session_id}")
    print(f"  Point your client to: {server.server_address[0]}:{server.server_address[1]}")
    print(f"\n  Use your OpenAI client with base_url=http://127.0.0.1:{port}/v1")
    print(f"  Ctrl+C to stop and analyze.\n")

    def shutdown(sig, frame):
        print("\n  Stopping proxy...")
        server.shutdown()

    signal.signal(signal.SIGINT, shutdown)
    signal.signal(signal.SIGTERM, shutdown)

    server.serve_forever()


# === CLI ===
def main():
    parser = argparse.ArgumentParser(
        description="Harmonia — Loop Collector & Optimizer for LLM workflows",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  harmonia track --label my_agent
  harmonia proxy --port 8090
  harmonia optimize
  harmonia optimize --session_id abc123
  harmonia viz
  harmonia sessions
  harmonia models
        """
    )
    parser.add_argument("--version", action="version", version=f"Harmonia v{VERSION}")

    subparsers = parser.add_subparsers(dest="command", required=True)

    # track
    p_track = subparsers.add_parser("track", help="Start a new tracking session")
    p_track.add_argument("--label", default=None, help="Session label")

    # proxy
    p_proxy = subparsers.add_parser("proxy", help="Start proxy mode (intercepts API calls)")
    p_proxy.add_argument("--port", type=int, default=8090, help="Proxy port (default: 8090)")

    # optimize
    p_opt = subparsers.add_parser("optimize", help="Analyze and optimize a session")
    p_opt.add_argument("--session_id", default=None, help="Session ID (default: latest)")

    # viz
    p_viz = subparsers.add_parser("viz", help="Visualize a session")
    p_viz.add_argument("--session_id", default=None, help="Session ID (default: latest)")

    # sessions
    subparsers.add_parser("sessions", help="List all sessions")

    # models
    p_models = subparsers.add_parser("models", help="Quick benchmark")
    p_models.add_argument("--api-url", default=None)
    p_models.add_argument("--api-key", default=None)

    args = parser.parse_args()

    init_db()

    if args.command == "track":
        cmd_track(args)
    elif args.command == "proxy":
        cmd_proxy(args)
    elif args.command == "optimize":
        cmd_optimize(args)
    elif args.command == "viz":
        cmd_viz(args)
    elif args.command == "sessions":
        cmd_sessions(args)
    elif args.command == "models":
        cmd_models(args)


if __name__ == "__main__":
    main()
